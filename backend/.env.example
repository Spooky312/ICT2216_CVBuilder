FLASK_ENV=development
SECRET_KEY=replace-with-strong-random-secret
JWT_SECRET_KEY=replace-with-strong-jwt-secret
DATABASE_URL=postgresql://cvbuilder:cvbuilder@db:5432/cvbuilder
REDIS_URL=redis://redis:6379/0
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@cvbuilder.local
FRONTEND_URL=http://localhost:3000

# Preset admin account (consumed by seed_admin.py on container boot).
# Leave ADMIN_PASSWORD blank to skip seeding the admin.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
